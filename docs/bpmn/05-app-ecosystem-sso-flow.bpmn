      <!-- ── Message Flows ── -->
      <!-- A: User opens web -->
      <bpmndi:BPMNEdge id="E_MFA1" bpmnElement="MFA1"><di:waypoint x="308" y="164"/><di:waypoint x="308" y="220"/></bpmndi:BPMNEdge>
      <!-- A: Web redirects to IDP -->
      <bpmndi:BPMNEdge id="E_MFA2" bpmnElement="MFA2"><di:waypoint x="493" y="354"/><di:waypoint x="493" y="402"/><di:waypoint x="298" y="402"/><di:waypoint x="298" y="450"/></bpmndi:BPMNEdge>
      <!-- A: IDP shows login to user -->
      <bpmndi:BPMNEdge id="E_MFA3" bpmnElement="MFA3"><di:waypoint x="478" y="450"/><di:waypoint x="478" y="402"/><di:waypoint x="573" y="402"/><di:waypoint x="573" y="164"/></bpmndi:BPMNEdge>
      <!-- A: User submits login -->
      <bpmndi:BPMNEdge id="E_MFA4" bpmnElement="MFA4"><di:waypoint x="648" y="164"/><di:waypoint x="648" y="402"/><di:waypoint x="663" y="402"/><di:waypoint x="663" y="478"/></bpmndi:BPMNEdge>
      <!-- A: IDP issues code → web callback -->
      <bpmndi:BPMNEdge id="E_MFA5" bpmnElement="MFA5"><di:waypoint x="1043" y="478"/><di:waypoint x="1043" y="402"/><di:waypoint x="678" y="402"/><di:waypoint x="678" y="354"/></bpmndi:BPMNEdge>
      <!-- A: Web exchanges code (server→IDP) -->
      <bpmndi:BPMNEdge id="E_MFA6" bpmnElement="MFA6"><di:waypoint x="863" y="280"/><di:waypoint x="863" y="230"/><di:waypoint x="1233" y="230"/><di:waypoint x="1233" y="478"/></bpmndi:BPMNEdge>
      <!-- A: IDP returns tokens to web -->
      <bpmndi:BPMNEdge id="E_MFA7" bpmnElement="MFA7"><di:waypoint x="1428" y="478"/><di:waypoint x="1428" y="230"/><di:waypoint x="1063" y="230"/><di:waypoint x="1063" y="280"/></bpmndi:BPMNEdge>
      <!-- A: Web serves app to user -->
      <bpmndi:BPMNEdge id="E_MFA8" bpmnElement="MFA8"><di:waypoint x="1263" y="280"/><di:waypoint x="1263" y="230"/><di:waypoint x="828" y="230"/><di:waypoint x="828" y="164"/></bpmndi:BPMNEdge>

      <!-- B: User opens mobile -->
      <bpmndi:BPMNEdge id="E_MFB1" bpmnElement="MFB1"><di:waypoint x="1058" y="164"/><di:waypoint x="1058" y="230"/><di:waypoint x="293" y="230"/><di:waypoint x="293" y="850"/></bpmndi:BPMNEdge>
      <!-- B: Mobile PKCE → IDP authz -->
      <bpmndi:BPMNEdge id="E_MFB2" bpmnElement="MFB2"><di:waypoint x="683" y="916"/><di:waypoint x="683" y="840"/><di:waypoint x="298" y="840"/><di:waypoint x="298" y="652"/></bpmndi:BPMNEdge>
      <!-- B: IDP SSO → code back to mobile (no login screen) -->
      <bpmndi:BPMNEdge id="E_MFB3" bpmnElement="MFB3"><di:waypoint x="568" y="578"/><di:waypoint x="568" y="840"/><di:waypoint x="873" y="840"/><di:waypoint x="873" y="916"/></bpmndi:BPMNEdge>
      <!-- B: Mobile exchanges code -->
      <bpmndi:BPMNEdge id="E_MFB4" bpmnElement="MFB4"><di:waypoint x="1068" y="916"/><di:waypoint x="1068" y="840"/><di:waypoint x="683" y="840"/><di:waypoint x="683" y="652"/></bpmndi:BPMNEdge>
      <!-- B: IDP issues token to mobile -->
      <bpmndi:BPMNEdge id="E_MFB5" bpmnElement="MFB5"><di:waypoint x="873" y="578"/><di:waypoint x="873" y="780"/><di:waypoint x="1263" y="780"/><di:waypoint x="1263" y="916"/></bpmndi:BPMNEdge>

      <!-- C: User opens form app -->
      <bpmndi:BPMNEdge id="E_MFC1" bpmnElement="MFC1"><di:waypoint x="1288" y="164"/><di:waypoint x="1288" y="190"/><di:waypoint x="293" y="190"/><di:waypoint x="293" y="1080"/></bpmndi:BPMNEdge>
      <!-- C: Form POST creds → IDP -->
      <bpmndi:BPMNEdge id="E_MFC2" bpmnElement="MFC2"><di:waypoint x="488" y="1131"/><di:waypoint x="488" y="1070"/><di:waypoint x="293" y="1070"/><di:waypoint x="293" y="810"/></bpmndi:BPMNEdge>
      <!-- C: IDP returns token -->
      <bpmndi:BPMNEdge id="E_MFC3" bpmnElement="MFC3"><di:waypoint x="683" y="678"/><di:waypoint x="683" y="1070"/><di:waypoint x="693" y="1070"/><di:waypoint x="693" y="1131"/></bpmndi:BPMNEdge>

      <!-- D: M2M → IDP client_credentials -->
      <bpmndi:BPMNEdge id="E_MFD1" bpmnElement="MFD1"><di:waypoint x="488" y="1331"/><di:waypoint x="488" y="1270"/><di:waypoint x="298" y="1270"/><di:waypoint x="298" y="832"/></bpmndi:BPMNEdge>
      <!-- D: IDP issues M2M token -->
      <bpmndi:BPMNEdge id="E_MFD2" bpmnElement="MFD2"><di:waypoint x="493" y="758"/><di:waypoint x="493" y="1270"/><di:waypoint x="693" y="1270"/><di:waypoint x="693" y="1405"/></bpmndi:BPMNEdge>

      <!-- E: JWKS flows (resource server validation) -->
      <bpmndi:BPMNEdge id="E_MFE1" bpmnElement="MFE1"><di:waypoint x="1633" y="478"/><di:waypoint x="1633" y="402"/><di:waypoint x="1463" y="402"/><di:waypoint x="1463" y="354"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_MFE2" bpmnElement="MFE2"><di:waypoint x="1633" y="652"/><di:waypoint x="1633" y="820"/><di:waypoint x="1643" y="820"/><di:waypoint x="1643" y="916"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_MFE3" bpmnElement="MFE3"><di:waypoint x="1633" y="752"/><di:waypoint x="1633" y="1270"/><di:waypoint x="1073" y="1270"/><di:waypoint x="1073" y="1405"/></bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
