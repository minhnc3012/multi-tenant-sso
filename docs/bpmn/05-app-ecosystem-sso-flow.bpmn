<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_SSO"
  targetNamespace="http://identityplatform.com/bpmn">

  <!--
    PROCESS: App Ecosystem SSO Flow
    Shows how all 4 client apps interact with the central IDP (Auth Server :8080)

    Flows covered:
      A) Web App (realestate-app :8081)  — authorization_code + client_secret  → FIRST login (establishes SSO session)
      B) Mobile PKCE (mobile-client-sample) — authorization_code + PKCE, no secret → SSO: re-uses IDP session, no re-login
      C) Mobile Form  (mobile-client-sample-form) — POST /api/auth/token (first-party, no browser)
      D) M2M API      (api-client-sample :8083)   — client_credentials (service-to-service)

    All tokens are JWT signed with same RSA key (kid from auth_key_pair table).
    Resource servers validate tokens via JWKS endpoint: GET /oauth2/jwks
  -->

  <bpmn:collaboration id="Collab_SSO">

    <!-- Pools -->
    <bpmn:participant id="Pool_User"        name="User (Browser + Mobile)"         processRef="Proc_User"/>
    <bpmn:participant id="Pool_WebApp"      name="realestate-app  :8081  (WEB_CLIENT)"   processRef="Proc_WebApp"/>
    <bpmn:participant id="Pool_IDP"         name="Auth Server / IDP  :8080"        processRef="Proc_IDP"/>
    <bpmn:participant id="Pool_MobilePKCE"  name="mobile-client-sample  (PKCE)"    processRef="Proc_MobilePKCE"/>
    <bpmn:participant id="Pool_MobileForm"  name="mobile-client-sample-form  (Form login)" processRef="Proc_MobileForm"/>
    <bpmn:participant id="Pool_M2M"         name="api-client-sample  :8083  (M2M)"  processRef="Proc_M2M"/>

    <!-- ── FLOW A: Web App authorization_code ── -->
    <bpmn:messageFlow id="MFA1" name="GET /  (unauthenticated)"           sourceRef="Task_U_OpenWeb"      targetRef="Task_W_CheckAuth"/>
    <bpmn:messageFlow id="MFA2" name="302 → /oauth2/authorize?&#10;client_id=realestate-web-client&#10;&amp;response_type=code&amp;state=..."
                                                                           sourceRef="Task_W_Redirect"     targetRef="Task_I_AuthzRequest"/>
    <bpmn:messageFlow id="MFA3" name="Show login page"                    sourceRef="Task_I_ShowLogin"     targetRef="Task_U_Login"/>
    <bpmn:messageFlow id="MFA4" name="POST /login (username+password)"    sourceRef="Task_U_Login"         targetRef="Task_I_Authenticate"/>
    <bpmn:messageFlow id="MFA5" name="302 → /callback?code=AUTH_CODE&amp;state=..." sourceRef="Task_I_IssueCode_A" targetRef="Task_W_ReceiveCode"/>
    <bpmn:messageFlow id="MFA6" name="POST /oauth2/token&#10;grant=authorization_code&#10;client_secret (Basic Auth)"
                                                                           sourceRef="Task_W_ExchangeCode" targetRef="Task_I_ValidateCodeA"/>
    <bpmn:messageFlow id="MFA7" name="200 {access_token, id_token, refresh_token}" sourceRef="Task_I_IssueTokenA" targetRef="Task_W_StoreToken"/>
    <bpmn:messageFlow id="MFA8" name="200 Dashboard (with Bearer token)"  sourceRef="Task_W_ServeApp"      targetRef="Task_U_UseWebApp"/>

    <!-- ── FLOW B: Mobile PKCE — SSO (no re-login) ── -->
    <bpmn:messageFlow id="MFB1" name="Open mobile app"                    sourceRef="Task_U_OpenMobile"    targetRef="Task_P_CheckSession"/>
    <bpmn:messageFlow id="MFB2" name="GET /oauth2/authorize?&#10;client_id=realestate-mobile-client&#10;&amp;code_challenge=S256&amp;..."
                                                                           sourceRef="Task_P_AuthzReq"      targetRef="Task_I_AuthzRequest_B"/>
    <bpmn:messageFlow id="MFB3" name="IDP session cookie valid →&#10;302 → app://callback?code=..."      sourceRef="Task_I_IssueCode_B"   targetRef="Task_P_ReceiveCode"/>
    <bpmn:messageFlow id="MFB4" name="POST /oauth2/token&#10;grant=authorization_code&#10;+code_verifier (no secret)"
                                                                           sourceRef="Task_P_ExchangeCode"  targetRef="Task_I_ValidateCodeB"/>
    <bpmn:messageFlow id="MFB5" name="200 {access_token}"                 sourceRef="Task_I_IssueTokenB"   targetRef="Task_P_StoreToken"/>

    <!-- ── FLOW C: Mobile Form (first-party, no browser) ── -->
    <bpmn:messageFlow id="MFC1" name="Open form login screen"             sourceRef="Task_U_OpenForm"      targetRef="Task_F_ShowForm"/>
    <bpmn:messageFlow id="MFC2" name="POST /api/auth/token&#10;username+password (x-www-form-urlencoded)" sourceRef="Task_F_PostCreds"     targetRef="Task_I_FormAuth"/>
    <bpmn:messageFlow id="MFC3" name="200 {access_token, expires_in}"     sourceRef="Task_I_IssueTokenC"   targetRef="Task_F_StoreToken"/>

    <!-- ── FLOW D: M2M client_credentials ── -->
    <bpmn:messageFlow id="MFD1" name="POST /oauth2/token&#10;grant=client_credentials&#10;client_secret (Basic Auth)"
                                                                           sourceRef="Task_M_GetToken"      targetRef="Task_I_ClientCreds"/>
    <bpmn:messageFlow id="MFD2" name="200 {access_token} (no refresh)"    sourceRef="Task_I_IssueTokenD"   targetRef="Task_M_CacheToken"/>

    <!-- ── FLOW E: All apps call Resource Server API with Bearer token ── -->
    <bpmn:messageFlow id="MFE1" name="GET /oauth2/jwks  (cache 1h)"       sourceRef="Task_I_ServeJWKS"     targetRef="Task_W_ValidateRS"/>
    <bpmn:messageFlow id="MFE2" name="GET /oauth2/jwks"                    sourceRef="Task_I_ServeJWKS2"    targetRef="Task_P_ValidateRS"/>
    <bpmn:messageFlow id="MFE3" name="GET /oauth2/jwks"                    sourceRef="Task_I_ServeJWKS3"    targetRef="Task_M_ValidateRS"/>

  </bpmn:collaboration>

  <!-- ══════════════════════════════════════════════════════════
       POOL: USER
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_User" isExecutable="false">
    <bpmn:startEvent  id="Start_User"       name="Muốn dùng&#10;ứng dụng"/>
    <bpmn:userTask    id="Task_U_OpenWeb"   name="Mở realestate-app&#10;http://localhost:8081"/>
    <bpmn:userTask    id="Task_U_Login"     name="Nhập username + password&#10;tại IDP login page"/>
    <bpmn:userTask    id="Task_U_UseWebApp" name="Dùng Web App&#10;(đã đăng nhập)"/>
    <bpmn:userTask    id="Task_U_OpenMobile" name="Mở Mobile App&#10;(PKCE — cùng tài khoản)"/>
    <bpmn:userTask    id="Task_U_OpenForm"  name="Mở Mobile Form App&#10;(first-party login)"/>
    <bpmn:endEvent    id="End_User"         name="Dùng được&#10;tất cả apps"/>

    <bpmn:sequenceFlow id="SF_U1" sourceRef="Start_User"        targetRef="Task_U_OpenWeb"/>
    <bpmn:sequenceFlow id="SF_U2" sourceRef="Task_U_UseWebApp"  targetRef="Task_U_OpenMobile"/>
    <bpmn:sequenceFlow id="SF_U3" sourceRef="Task_U_OpenMobile" targetRef="Task_U_OpenForm"/>
    <bpmn:sequenceFlow id="SF_U4" sourceRef="Task_U_OpenForm"   targetRef="End_User"/>
  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════
       POOL: WEB APP (realestate-app :8081)
       Flow A — authorization_code + client_secret
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_WebApp" isExecutable="false">
    <bpmn:startEvent  id="Start_WebApp"/>
    <bpmn:serviceTask id="Task_W_CheckAuth"   name="Check session cookie&#10;→ not authenticated"/>
    <bpmn:serviceTask id="Task_W_Redirect"    name="Build /oauth2/authorize URL&#10;state=random, scope=openid profile&#10;redirect_uri=http://localhost:8081/callback"/>
    <bpmn:serviceTask id="Task_W_ReceiveCode" name="GET /callback?code=AUTH_CODE&#10;Verify state param"/>
    <bpmn:serviceTask id="Task_W_ExchangeCode" name="POST /oauth2/token&#10;(server-side, secret not exposed)&#10;code + redirect_uri + client_secret"/>
    <bpmn:serviceTask id="Task_W_StoreToken"  name="Store access_token in session&#10;Store refresh_token (httpOnly cookie)&#10;Parse id_token claims"/>
    <bpmn:serviceTask id="Task_W_ServeApp"    name="Render dashboard&#10;Attach Authorization: Bearer {token}&#10;to all API calls"/>
    <bpmn:serviceTask id="Task_W_ValidateRS"  name="Fetch JWKS from IDP&#10;(cache public key)&#10;Validate incoming Bearer tokens"/>
    <bpmn:endEvent    id="End_WebApp"/>

    <bpmn:sequenceFlow id="SF_W1" sourceRef="Start_WebApp"       targetRef="Task_W_CheckAuth"/>
    <bpmn:sequenceFlow id="SF_W2" sourceRef="Task_W_CheckAuth"   targetRef="Task_W_Redirect"/>
    <bpmn:sequenceFlow id="SF_W3" sourceRef="Task_W_ReceiveCode" targetRef="Task_W_ExchangeCode"/>
    <bpmn:sequenceFlow id="SF_W4" sourceRef="Task_W_ExchangeCode" targetRef="Task_W_StoreToken"/>
    <bpmn:sequenceFlow id="SF_W5" sourceRef="Task_W_StoreToken"  targetRef="Task_W_ServeApp"/>
    <bpmn:sequenceFlow id="SF_W6" sourceRef="Task_W_ServeApp"    targetRef="Task_W_ValidateRS"/>
    <bpmn:sequenceFlow id="SF_W7" sourceRef="Task_W_ValidateRS"  targetRef="End_WebApp"/>
  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════
       POOL: AUTH SERVER / IDP :8080
       Central — handles all flows
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_IDP" isExecutable="false">

    <!-- FLOW A: Web app authorization_code -->
    <bpmn:startEvent  id="Start_IDP_A"        name="[A] authz request"/>
    <bpmn:serviceTask id="Task_I_AuthzRequest" name="OrgClientAuthorizationFilter&#10;Verify: client_id orgId match&#10;Check redirect_uri whitelist"/>
    <bpmn:serviceTask id="Task_I_ShowLogin"    name="Show /login page&#10;(Spring Security form login)"/>
    <bpmn:serviceTask id="Task_I_Authenticate" name="MultiTenantUserDetailsService&#10;Load user by email + org_id&#10;BCrypt password verify"/>
    <bpmn:serviceTask id="Task_I_SetSession"   name="Set IDP session cookie&#10;(JSESSIONID — SSO session start)"/>
    <bpmn:serviceTask id="Task_I_IssueCode_A"  name="Generate authorization_code&#10;Store in oauth2_authorization table&#10;TTL = 5 min"/>
    <bpmn:serviceTask id="Task_I_ValidateCodeA" name="Validate code + redirect_uri&#10;Verify client_secret (Basic Auth)&#10;Delete used code (one-time)"/>
    <bpmn:serviceTask id="Task_I_IssueTokenA"  name="MultiTenantTokenCustomizer&#10;Add: org_id, roles, permissions&#10;Sign JWT with RSA key (auth_key_pair)&#10;Issue access_token + id_token + refresh_token"/>

    <!-- FLOW B: Mobile PKCE — SSO (no re-login) -->
    <bpmn:startEvent  id="Start_IDP_B"         name="[B] PKCE authz request"/>
    <bpmn:serviceTask id="Task_I_AuthzRequest_B" name="Check: code_challenge present&#10;Verify client_id (public, no secret)&#10;IDP session cookie? → YES (SSO!)"/>
    <bpmn:serviceTask id="Task_I_IssueCode_B"   name="Skip login — session valid&#10;Generate authorization_code&#10;Store code_challenge (S256)"/>
    <bpmn:serviceTask id="Task_I_ValidateCodeB" name="Verify code_verifier SHA256&#10;= stored code_challenge&#10;No client_secret needed"/>
    <bpmn:serviceTask id="Task_I_IssueTokenB"   name="Issue access_token&#10;Same RSA key, same claims&#10;No refresh_token for public clients"/>

    <!-- FLOW C: Form login (MobileAuthController) -->
    <bpmn:startEvent  id="Start_IDP_C"        name="[C] POST /api/auth/token"/>
    <bpmn:serviceTask id="Task_I_RateLimit"    name="LoginRateLimitFilter&#10;Redis INCR rl:login:{ip}&#10;10 attempts / 60s"/>
    <bpmn:serviceTask id="Task_I_FormAuth"     name="MobileAuthController&#10;AuthenticationManager.authenticate()&#10;→ MultiTenantUserDetailsService"/>
    <bpmn:serviceTask id="Task_I_IssueTokenC"  name="JwtEncoder.encode()&#10;Same RSA key&#10;NOTE: not in oauth2_authorization table"/>

    <!-- FLOW D: M2M client_credentials -->
    <bpmn:startEvent  id="Start_IDP_D"        name="[D] client_credentials"/>
    <bpmn:serviceTask id="Task_I_ClientCreds"  name="Verify client_secret (Basic Auth)&#10;Grant type: client_credentials&#10;No user context"/>
    <bpmn:serviceTask id="Task_I_IssueTokenD"  name="Issue access_token&#10;scope: api:read api:write&#10;No refresh_token"/>

    <!-- SHARED: JWKS endpoint (all resource servers fetch this) -->
    <bpmn:serviceTask id="Task_I_ServeJWKS"    name="GET /oauth2/jwks&#10;Return public key (RSA)&#10;from auth_key_pair table"/>
    <bpmn:serviceTask id="Task_I_ServeJWKS2"   name="GET /oauth2/jwks (PKCE RS)"/>
    <bpmn:serviceTask id="Task_I_ServeJWKS3"   name="GET /oauth2/jwks (M2M RS)"/>

    <bpmn:endEvent id="End_IDP_A"/>
    <bpmn:endEvent id="End_IDP_B"/>
    <bpmn:endEvent id="End_IDP_C"/>
    <bpmn:endEvent id="End_IDP_D"/>

    <!-- Flow A -->
    <bpmn:sequenceFlow id="SF_IA1"  sourceRef="Start_IDP_A"         targetRef="Task_I_AuthzRequest"/>
    <bpmn:sequenceFlow id="SF_IA2"  sourceRef="Task_I_AuthzRequest"  targetRef="Task_I_ShowLogin"/>
    <bpmn:sequenceFlow id="SF_IA3"  sourceRef="Task_I_Authenticate"  targetRef="Task_I_SetSession"/>
    <bpmn:sequenceFlow id="SF_IA4"  sourceRef="Task_I_SetSession"    targetRef="Task_I_IssueCode_A"/>
    <bpmn:sequenceFlow id="SF_IA5"  sourceRef="Task_I_ValidateCodeA" targetRef="Task_I_IssueTokenA"/>
    <bpmn:sequenceFlow id="SF_IA6"  sourceRef="Task_I_IssueTokenA"   targetRef="End_IDP_A"/>
    <!-- Flow B -->
    <bpmn:sequenceFlow id="SF_IB1"  sourceRef="Start_IDP_B"          targetRef="Task_I_AuthzRequest_B"/>
    <bpmn:sequenceFlow id="SF_IB2"  sourceRef="Task_I_AuthzRequest_B" targetRef="Task_I_IssueCode_B"/>
    <bpmn:sequenceFlow id="SF_IB3"  sourceRef="Task_I_ValidateCodeB"  targetRef="Task_I_IssueTokenB"/>
    <bpmn:sequenceFlow id="SF_IB4"  sourceRef="Task_I_IssueTokenB"    targetRef="End_IDP_B"/>
    <!-- Flow C -->
    <bpmn:sequenceFlow id="SF_IC1"  sourceRef="Start_IDP_C"          targetRef="Task_I_RateLimit"/>
    <bpmn:sequenceFlow id="SF_IC2"  sourceRef="Task_I_RateLimit"      targetRef="Task_I_FormAuth"/>
    <bpmn:sequenceFlow id="SF_IC3"  sourceRef="Task_I_FormAuth"       targetRef="Task_I_IssueTokenC"/>
    <bpmn:sequenceFlow id="SF_IC4"  sourceRef="Task_I_IssueTokenC"    targetRef="End_IDP_C"/>
    <!-- Flow D -->
    <bpmn:sequenceFlow id="SF_ID1"  sourceRef="Start_IDP_D"          targetRef="Task_I_ClientCreds"/>
    <bpmn:sequenceFlow id="SF_ID2"  sourceRef="Task_I_ClientCreds"    targetRef="Task_I_IssueTokenD"/>
    <bpmn:sequenceFlow id="SF_ID3"  sourceRef="Task_I_IssueTokenD"    targetRef="End_IDP_D"/>
  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════
       POOL: MOBILE PKCE (mobile-client-sample)
       Flow B — authorization_code + PKCE, no secret
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_MobilePKCE" isExecutable="false">
    <bpmn:startEvent  id="Start_PKCE"/>
    <bpmn:serviceTask id="Task_P_CheckSession" name="Check stored access_token&#10;→ not found / expired"/>
    <bpmn:serviceTask id="Task_P_GenPKCE"      name="Generate code_verifier (random 43-128 chars)&#10;code_challenge = BASE64URL(SHA256(verifier))"/>
    <bpmn:serviceTask id="Task_P_AuthzReq"     name="expo-auth-session&#10;Open browser to /oauth2/authorize&#10;client_id=realestate-mobile-client&#10;code_challenge_method=S256"/>
    <bpmn:serviceTask id="Task_P_ReceiveCode"  name="Browser redirects to&#10;app://callback?code=...&#10;Expo deep link → app receives code"/>
    <bpmn:serviceTask id="Task_P_ExchangeCode" name="POST /oauth2/token&#10;code + code_verifier&#10;NO client_secret (public client)"/>
    <bpmn:serviceTask id="Task_P_StoreToken"   name="SecureStore.setItemAsync()&#10;Store access_token + expiry&#10;(Expo Secure Storage)"/>
    <bpmn:serviceTask id="Task_P_CallAPI"      name="GET /api/v1/properties&#10;Authorization: Bearer {token}&#10;X-Organization-Slug: realestate-corp"/>
    <bpmn:serviceTask id="Task_P_ValidateRS"   name="Resource Server&#10;Fetch JWKS, validate JWT&#10;Check org_id claim"/>
    <bpmn:endEvent    id="End_PKCE"/>

    <bpmn:sequenceFlow id="SF_P1" sourceRef="Start_PKCE"           targetRef="Task_P_CheckSession"/>
    <bpmn:sequenceFlow id="SF_P2" sourceRef="Task_P_CheckSession"  targetRef="Task_P_GenPKCE"/>
    <bpmn:sequenceFlow id="SF_P3" sourceRef="Task_P_GenPKCE"       targetRef="Task_P_AuthzReq"/>
    <bpmn:sequenceFlow id="SF_P4" sourceRef="Task_P_ReceiveCode"   targetRef="Task_P_ExchangeCode"/>
    <bpmn:sequenceFlow id="SF_P5" sourceRef="Task_P_ExchangeCode"  targetRef="Task_P_StoreToken"/>
    <bpmn:sequenceFlow id="SF_P6" sourceRef="Task_P_StoreToken"    targetRef="Task_P_CallAPI"/>
    <bpmn:sequenceFlow id="SF_P7" sourceRef="Task_P_CallAPI"       targetRef="Task_P_ValidateRS"/>
    <bpmn:sequenceFlow id="SF_P8" sourceRef="Task_P_ValidateRS"    targetRef="End_PKCE"/>
  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════
       POOL: MOBILE FORM (mobile-client-sample-form)
       Flow C — POST /api/auth/token (first-party)
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_MobileForm" isExecutable="false">
    <bpmn:startEvent  id="Start_Form"/>
    <bpmn:serviceTask id="Task_F_ShowForm"   name="Render native form&#10;(no browser, no redirect)&#10;TextInput: email + password"/>
    <bpmn:serviceTask id="Task_F_PostCreds"  name="POST /api/auth/token&#10;Content-Type: application/x-www-form-urlencoded&#10;X-Organization-Slug: realestate-corp"/>
    <bpmn:serviceTask id="Task_F_StoreToken" name="AsyncStorage / SecureStore&#10;Store access_token&#10;(⚠ no refresh_token — re-login on expiry)"/>
    <bpmn:serviceTask id="Task_F_CallAPI"    name="Call API with Bearer token&#10;Same JWT claims as PKCE flow"/>
    <bpmn:endEvent    id="End_Form"/>

    <bpmn:sequenceFlow id="SF_F1" sourceRef="Start_Form"         targetRef="Task_F_ShowForm"/>
    <bpmn:sequenceFlow id="SF_F2" sourceRef="Task_F_ShowForm"    targetRef="Task_F_PostCreds"/>
    <bpmn:sequenceFlow id="SF_F3" sourceRef="Task_F_StoreToken"  targetRef="Task_F_CallAPI"/>
    <bpmn:sequenceFlow id="SF_F4" sourceRef="Task_F_CallAPI"     targetRef="End_Form"/>
  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════
       POOL: M2M API CLIENT (api-client-sample :8083)
       Flow D — client_credentials (no user)
       ══════════════════════════════════════════════════════════ -->
  <bpmn:process id="Proc_M2M" isExecutable="false">
    <bpmn:startEvent  id="Start_M2M"/>
    <bpmn:serviceTask id="Task_M_CheckCache"  name="Check token cache&#10;→ expired / not found"/>
    <bpmn:serviceTask id="Task_M_GetToken"    name="POST /oauth2/token&#10;grant_type=client_credentials&#10;Authorization: Basic {clientId:secret}&#10;scope=api:read api:write"/>
    <bpmn:serviceTask id="Task_M_CacheToken"  name="Cache token in memory&#10;expires_in - 60s buffer"/>
    <bpmn:serviceTask id="Task_M_CallAPI"     name="GET /api/v1/data (internal)&#10;Authorization: Bearer {token}&#10;No X-Organization-Slug needed&#10;(org embedded in token claims)"/>
    <bpmn:serviceTask id="Task_M_ValidateRS"  name="Resource Server&#10;Validate JWT: iss, exp, scope&#10;No org_id check (service account)"/>
    <bpmn:endEvent    id="End_M2M"/>

    <bpmn:sequenceFlow id="SF_M1" sourceRef="Start_M2M"          targetRef="Task_M_CheckCache"/>
    <bpmn:sequenceFlow id="SF_M2" sourceRef="Task_M_CheckCache"   targetRef="Task_M_GetToken"/>
    <bpmn:sequenceFlow id="SF_M3" sourceRef="Task_M_CacheToken"   targetRef="Task_M_CallAPI"/>
    <bpmn:sequenceFlow id="SF_M4" sourceRef="Task_M_CallAPI"      targetRef="Task_M_ValidateRS"/>
    <bpmn:sequenceFlow id="SF_M5" sourceRef="Task_M_ValidateRS"   targetRef="End_M2M"/>
  </bpmn:process>

  <!-- ═══════════════════════════════ DIAGRAM LAYOUT ════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_5">
    <bpmndi:BPMNPlane id="BPMNPlane_5" bpmnElement="Collab_SSO">

      <!-- USER POOL  y=60 h=130 -->
      <bpmndi:BPMNShape id="S_Pool_User" bpmnElement="Pool_User" isHorizontal="true">
        <dc:Bounds x="100" y="60" width="1760" height="130"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Start_User"       bpmnElement="Start_User">        <dc:Bounds x="162" y="109" width="36"  height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_U_OpenWeb"         bpmnElement="Task_U_OpenWeb">    <dc:Bounds x="238" y="90"  width="140" height="74"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_U_Login"           bpmnElement="Task_U_Login">      <dc:Bounds x="498" y="90"  width="150" height="74"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_U_UseWebApp"       bpmnElement="Task_U_UseWebApp">  <dc:Bounds x="758" y="90"  width="140" height="74"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_U_OpenMobile"      bpmnElement="Task_U_OpenMobile"> <dc:Bounds x="988" y="90"  width="140" height="74"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_U_OpenForm"        bpmnElement="Task_U_OpenForm">   <dc:Bounds x="1218" y="90" width="140" height="74"/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End_User"          bpmnElement="End_User">          <dc:Bounds x="1758" y="109" width="36" height="36"/></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="E_U1" bpmnElement="SF_U1"><di:waypoint x="198" y="127"/><di:waypoint x="238" y="127"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_U2" bpmnElement="SF_U2"><di:waypoint x="898" y="127"/><di:waypoint x="988" y="127"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_U3" bpmnElement="SF_U3"><di:waypoint x="1128" y="127"/><di:waypoint x="1218" y="127"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_U4" bpmnElement="SF_U4"><di:waypoint x="1358" y="127"/><di:waypoint x="1758" y="127"/></bpmndi:BPMNEdge>

      <!-- WEB APP POOL  y=220 h=200 -->
      <bpmndi:BPMNShape id="S_Pool_WebApp" bpmnElement="Pool_WebApp" isHorizontal="true">
